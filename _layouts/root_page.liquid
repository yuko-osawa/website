---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {% assign personal_post = site.static | where: 'static_content', page.static_content_ref | first %}
    {{ personal_post.content }}

    {{ content }}
  </article>
</div>
